---
import BaseLayout from "@/layouts/base-layout.astro";
import { categories, getTool, getToolsByCategory } from "@/lib/tools-registry";
import RecentTracker from "@/components/layout/recent-tracker.tsx";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const tool = getTool(slug);
if (!tool) throw new Error(`Tool not found: ${slug}`);

const category = categories.find((c) => c.id === tool.category);
const related = getToolsByCategory(tool.category)
  .filter((t) => t.slug !== tool.slug)
  .slice(0, 4);

const title = `${tool.name} — Toolnest`;
---

<BaseLayout title={title} description={tool.description}>
  <RecentTracker client:load slug={tool.slug} />

  <nav aria-label="Breadcrumb" class="mb-3 flex items-center gap-1.5 text-xs text-muted-foreground">
    <a href="/" class="transition-colors hover:text-foreground">Tools</a>
    {
      category && (
        <>
          <span class="text-muted-foreground/50">/</span>
          <span>{category.label}</span>
        </>
      )
    }
    <span class="text-muted-foreground/50">/</span>
    <span class="text-foreground">{tool.name}</span>
  </nav>

  <header class="mb-6">
    <h1 class="text-xl font-semibold tracking-tight sm:text-2xl">{tool.name}</h1>
    <p class="mt-1 text-sm text-muted-foreground">{tool.description}</p>
  </header>

  <slot />

  {
    related.length > 0 && (
      <section class="mt-12 border-t border-border pt-6">
        <h2 class="mb-3 text-xs font-medium text-muted-foreground">
          More in {category?.label ?? "this category"}
        </h2>
        <div class="grid gap-x-6 gap-y-1 sm:grid-cols-2 lg:grid-cols-4">
          {related.map((t) => {
            const Icon = t.icon;
            return (
              <a
                href={`/tools/${t.slug}`}
                class="group flex items-center gap-2 rounded-lg px-2.5 py-1.5 transition-all hover:bg-accent/50 hover:translate-x-0.5"
              >
                <Icon className="h-3.5 w-3.5 shrink-0 text-muted-foreground/60 group-hover:text-muted-foreground transition-colors" />
                <span class="truncate text-sm text-muted-foreground group-hover:text-foreground transition-colors">{t.name}</span>
              </a>
            );
          })}
        </div>
      </section>
    )
  }
</BaseLayout>
