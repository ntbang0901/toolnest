---
const year = new Date().getFullYear();
---

<footer class="mt-12 border-t border-border">
  <div
    class="mx-auto flex w-full max-w-7xl flex-col gap-2 px-4 py-6 text-xs text-muted-foreground sm:flex-row sm:items-center sm:justify-between"
  >
    <p>© {year} toolnest · runs in your browser</p>
    <a
      href="https://github.com"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-foreground"
    >
      Source on GitHub
    </a>
  </div>
</footer>
