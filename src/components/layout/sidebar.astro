---
import { categories, tools } from "@/lib/tools-registry";

const grouped = categories
  .map((cat) => ({
    ...cat,
    items: tools.filter((tool) => tool.category === cat.id),
  }))
  .filter((cat) => cat.items.length > 0);

const currentPath = Astro.url.pathname;
---

<aside class="hidden w-56 shrink-0 lg:block">
  <nav class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2">
    <ul class="flex flex-col gap-5 text-sm">
      {
        grouped.map((cat) => (
          <li>
            <div class="mb-2 px-2.5 text-[10px] font-semibold uppercase tracking-widest text-muted-foreground/50">
              {cat.label}
            </div>
            <ul class="flex flex-col">
              {cat.items.map((tool) => {
                const href = `/tools/${tool.slug}`;
                const active = currentPath === href;
                return (
                  <li>
                    <a
                      href={href}
                      class:list={[
                        "block rounded-lg px-2.5 py-1.5 text-sm transition-all",
                        active
                          ? "bg-primary/10 text-primary font-medium"
                          : "text-muted-foreground hover:bg-accent/60 hover:text-foreground hover:translate-x-0.5",
                      ]}
                    >
                      {tool.name}
                    </a>
                  </li>
                );
              })}
            </ul>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
